generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  role      String   @default("user")
  addedAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings  Bookings[]
  favorites Favorites[]
}

model Cars {
  id           String   @id @default(uuid())
  name         String
  image        String
  price        Float    // Changed to Float for mathematical sorting/filtering
  desc         String   @db.Text
  brand        String
  model        String
  year         Int      // Changed to Int for year filtering
  manufacturer String
  status       String   // e.g., "Available", "Sold"
  color        String
  type         String
  engine       String
  fuel         String
  transmission String
  isFeatured   Boolean  @default(false)
  date_of_entry DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relationships
  bookings     Bookings[]
  favoritedBy  Favorites[]
}

model Bookings {
  id      String @id @default(uuid())
  date    String // Or DateTime if you want strict scheduling
  time    String
  status  String @default("pending") // "pending", "confirmed", "cancelled"

  // Foreign Keys
  userId  String
  carId   String

  startTime String
  endTime   String

  // Relations: Connects the IDs to the actual models
  user    Users   @relation(fields: [userId], references: [id], onDelete: Cascade)
  car     Cars    @relation(fields: [carId], references: [id], onDelete: Cascade)
}

model Favorites {
  id      String @id @default(uuid())
  userId  String
  carId   String

  // Relations
  user    Users   @relation(fields: [userId], references: [id], onDelete: Cascade)
  car     Cars    @relation(fields: [carId], references: [id], onDelete: Cascade)

  // Prevents a user from favoriting the same car twice
  @@unique([userId, carId])
}